{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Generated by OTel Weaver from registry/signals.yaml. Run `make generate` to regenerate.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "title": "Pull Requests", "type": "row" }



    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Age of an open pull request in seconds (time since creation).",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 10,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github.pr.age{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github.pr.age",
      "type": "timeseries"
    }



    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total number of pull requests merged via automerge.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 11,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github.pr.automerged{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github.pr.automerged",
      "type": "timeseries"
    }



    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Time from PR creation to close (merged or declined) in seconds.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 12,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github.pr.close.duration{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github.pr.close.duration",
      "type": "timeseries"
    }



    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of open pull requests.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 13,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github.pr.count{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github.pr.count",
      "type": "timeseries"
    }



    ,{ "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }, "id": 100, "title": "Issues", "type": "row" }


    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Age of an open GitHub issue in seconds (time since creation).",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "id": 101,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github.issue.age{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github.issue.age",
      "type": "timeseries"
    }


    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of open GitHub issues.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "id": 102,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github.issue.count{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github.issue.count",
      "type": "timeseries"
    }


    ,{ "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 100 }, "id": 200, "title": "Renovate Dashboard", "type": "row" }


    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of pull requests in each section of the Renovate dependency dashboard.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 101 },
      "id": 201,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "renovate.dashboard.queue{job=\"$job\"}", "legendFormat": "{{renovate_dashboard_section}}", "refId": "A" }],
      "title": "renovate.dashboard.queue",
      "type": "timeseries"
    }


    ,{ "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 150 }, "id": 300, "title": "Exporter Self-Metrics", "type": "row" }


    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of GitHub API errors encountered during collection.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 151 },
      "id": 301,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github_exporter.api.errors{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github_exporter.api.errors",
      "type": "timeseries"
    }


    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of OTLP push failures.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 151 },
      "id": 302,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github_exporter.otlp.errors{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github_exporter.otlp.errors",
      "type": "timeseries"
    }


    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Duration of a complete collection cycle in seconds.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 159 },
      "id": 303,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "github_exporter.scrape.duration{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "github_exporter.scrape.duration",
      "type": "timeseries"
    }


  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["renovate", "github", "generated"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "label": "Data Source", "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource" },
      { "current": {}, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "definition": "label_values(github_exporter_scrape_duration_count, job)", "hide": 0, "includeAll": false, "label": "Job", "name": "job", "options": [], "query": { "query": "label_values(github_exporter_scrape_duration_count, job)", "refId": "StandardVariableQuery" }, "refresh": 2, "sort": 1, "type": "query" }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Renovate GitHub Exporter",
  "uid": "renovate-github-exporter",
  "version": 1
}