{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Generated by OTel Weaver from registry/signals.yaml. Run `make generate` to regenerate.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "title": "Pull Requests", "type": "row" }
{% set panel_id = namespace(v=10) %}
{% set pr_idx = namespace(v=0) %}
{% for metric in ctx %}{% if "github.pr" in metric.metric_name %}
    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "{{ metric.brief }}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": {{ (pr_idx.v % 2) * 12 }}, "y": {{ 1 + (pr_idx.v // 2) * 8 }} },
      "id": {{ panel_id.v }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "{{ metric.metric_name }}{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "{{ metric.metric_name }}",
      "type": "timeseries"
    }
{% set pr_idx.v = pr_idx.v + 1 %}
{% set panel_id.v = panel_id.v + 1 %}
{% endif %}{% endfor %}
    ,{ "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }, "id": 100, "title": "Issues", "type": "row" }
{% set iss_idx = namespace(v=0) %}
{% for metric in ctx %}{% if "github.issue" in metric.metric_name %}
    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "{{ metric.brief }}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": {{ (iss_idx.v % 2) * 12 }}, "y": {{ 51 + (iss_idx.v // 2) * 8 }} },
      "id": {{ 100 + iss_idx.v + 1 }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "{{ metric.metric_name }}{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "{{ metric.metric_name }}",
      "type": "timeseries"
    }
{% set iss_idx.v = iss_idx.v + 1 %}
{% endif %}{% endfor %}
    ,{ "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 100 }, "id": 200, "title": "Renovate Dashboard", "type": "row" }
{% set ren_idx = namespace(v=0) %}
{% for metric in ctx %}{% if "renovate." in metric.metric_name %}
    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "{{ metric.brief }}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": {{ 101 + ren_idx.v * 8 }} },
      "id": {{ 200 + ren_idx.v + 1 }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "{{ metric.metric_name }}{job=\"$job\"}", "legendFormat": "{{ '{{renovate_dashboard_section}}' }}", "refId": "A" }],
      "title": "{{ metric.metric_name }}",
      "type": "timeseries"
    }
{% set ren_idx.v = ren_idx.v + 1 %}
{% endif %}{% endfor %}
    ,{ "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 150 }, "id": 300, "title": "Exporter Self-Metrics", "type": "row" }
{% set sel_idx = namespace(v=0) %}
{% for metric in ctx %}{% if "github_exporter." in metric.metric_name %}
    ,{
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "{{ metric.brief }}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": {{ (sel_idx.v % 2) * 12 }}, "y": {{ 151 + (sel_idx.v // 2) * 8 }} },
      "id": {{ 300 + sel_idx.v + 1 }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "{{ metric.metric_name }}{job=\"$job\"}", "legendFormat": "__auto", "refId": "A" }],
      "title": "{{ metric.metric_name }}",
      "type": "timeseries"
    }
{% set sel_idx.v = sel_idx.v + 1 %}
{% endif %}{% endfor %}
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["renovate", "github", "generated"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "label": "Data Source", "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource" },
      { "current": {}, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "definition": "label_values(github_exporter_scrape_duration_count, job)", "hide": 0, "includeAll": false, "label": "Job", "name": "job", "options": [], "query": { "query": "label_values(github_exporter_scrape_duration_count, job)", "refId": "StandardVariableQuery" }, "refresh": 2, "sort": 1, "type": "query" }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Renovate GitHub Exporter",
  "uid": "renovate-github-exporter",
  "version": 1
}
